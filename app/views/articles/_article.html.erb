<div class="container">
    <div class="text-center">
        <%= link_to 'Create new article', new_article_path %>
    </div>
    <% @articles.each do |article| %>
        <div class="row justify-content-center">
            <div class="col-8 mt-4">
                <div class="card text-center shadow mb-5 bg-white rounded">
                    <div class="card-header fst-italic">
                        <% if article.user %>
                            by <%= link_to article.user.username, user_path(article.user), class: "text-decoration-none" %>
                        <% end %>
                        <% if article.categories.any? %>
                            <br>
                            <div class="mt-2"><%= render article.categories %></div>
                        <% end %>
                    </div>
                    <div class="card-body">
                        <h5 class="card-title"><%= link_to article.title, article_path(article), class: "text-black text-decoration-none" %></h5>
                        <p class="card-text"><%= truncate(article.description, length: 100) %></p>
                        <%= link_to 'View', article_path(article), class: "btn btn-outline-dark" %>
                        <% if logged_in? && (article.user == current_user || current_user.admin?) %>
                            <%= link_to "Edit", edit_article_path(article), class: "btn btn-outline-secondary" %>
                            <%= link_to "Delete", article_path(article), class: "btn btn-outline-danger", data: { turbo_method: :delete, turbo_confirm: "Are you sure?" } %>
                        <% end %>
                    </div>
                    <div class="card-footer text-muted">
                        <small>Created <%= time_ago_in_words(article.created_at) %> ago, 
                        edited <%= time_ago_in_words(article.updated_at) %> ago</small>
                    </div>
                </div>
            </div>
        </div>
    <% end %>
</div>