<div class="container">

    <div class="row justify-content-center">
        <div class="col-10 col-md-10 col-lg-8">
            <%= render 'shared/errors', obj: @article %>
            <div class="text-center mb-4">
                <%= link_to '← Return', articles_path %>
            </div>

            <%= form_with model: @article, class: "shadow p-3 mb-3 bg-info rounded", data: { turbo: false }, local: true do |f| %>
                <div class="form-group row align-items-center">
                    <%= f.label :title, class: "col-2 col-form-label text-light" %>
                    <div class="col-10">
                        <%= f.text_field :title, class: "form-control shadow rounded", placeholder: "Title of article" %>
                    </div>
                </div>

                <div class="form-group row">
                    <%= f.label :description, class: "col-2 col-form-label text-light" %>
                    <div class="col-10">
                        <%= f.text_area :description, rows: 10, class: "form-control mt-2 shadow rounded", placeholder: "Description of article" %>
                    </div>
                </div>
                
                <div class="form-group row align-items-center">
                    <div class="col-12 text-center mt-2">
                        <%= f.submit class: "btn btn-outline-dark btn-lg" %>
                    </div>
                </div>

            <% end %>
        </div>
    </div>
</div>