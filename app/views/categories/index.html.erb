<h1 class="text-center mt-2">Categories</h1>

<div class="apple_pagination">
    <%= will_paginate @categories, :container => false %>
</div>

<div class="container">
    <div class="text-center">
        <%= link_to 'Create new article', new_article_path %>
    </div>
    <% @categories.each do |category| %>
        <div class="row justify-content-center">
            <div class="col-4 mt-4">
                <div class="card text-center shadow mb-5 bg-white rounded">
                    <div class="card-body">
                        <h5 class="card-title"><%= link_to category.name, category_path(category), class: "text-black text-decoration-none" %></h5>
                    </div>
                    <div class="card-footer text-muted">
                        <small>Created <%= time_ago_in_words(category.created_at) %> ago, 
                        edited <%= time_ago_in_words(category.updated_at) %> ago</small>
                    </div>
                </div>
            </div>
        </div>
    <% end %>
</div>

<div class="apple_pagination mb-4">
    <%= will_paginate @categories, :container => false %>
</div>