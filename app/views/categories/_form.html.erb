<%= render 'shared/errors' , obj: @category%>
<div class="text-center mb-4">
    <%= link_to '← Return', categories_path %>
</div>

<%= form_with model: @category, class: "shadow p-3 mb-3 bg-info rounded", data: { turbo: false }, local: true do |f| %>
    <div class="form-group row align-items-center">
        <%= f.label :name, "Category Name", class: "col-2 col-form-label text-light" %>
        <div class="col-10">
            <%= f.text_field :name, class: "form-control shadow rounded", placeholder: "Enter a name" %>
        </div>
    </div>
    
    <div class="form-group row align-items-center">
        <div class="col-12 text-center mt-2">
            <%= f.submit class: "btn btn-outline-dark btn-lg" %>
        </div>
    </div>

<% end %>