<h1 class="text-center mt-2">Log in</h1>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-10 col-md-10 col-lg-8">
            <div class="text-center mb-4">
                <%= link_to '← Return', articles_path %>
            </div>

            <%= form_with scope: :session, url: login_path, class: "shadow p-3 mb-3 bg-info rounded", data: { turbo: false }, local: true do |f| %>
                <div class="form-group row align-items-center">
                    <%= f.label :username, class: "col-2 col-form-label text-light" %>
                    <div class="col-10">
                        <%= f.text_field :username, class: "form-control shadow rounded", placeholder: "Enter your username" %>
                    </div>
                </div>

                <div class="form-group row align-items-center">
                    <%= f.label :password, class: "col-2 col-form-label text-light" %>
                    <div class="col-10">
                        <%= f.password_field :password, class: "form-control mt-2 shadow rounded", placeholder: "Enter your password" %>
                    </div>
                </div>
                
                <div class="form-group row align-items-center">
                    <div class="col-12 text-center mt-2">
                        <%= f.submit "Log in", class: "btn btn-outline-dark btn-lg" %>
                    </div>
                </div>

            <% end %>
        </div>
    </div>
</div>